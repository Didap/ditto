# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Auth (NextAuth v5) ───────────────────────────────────────
# Required. Generate with: npx auth secret
AUTH_SECRET=

# ─── Admin allowlist ──────────────────────────────────────────
# Comma-separated emails granted access to /admin/users.
# Example: ADMIN_EMAILS=founder@example.com,ops@example.com
ADMIN_EMAILS=

# ─── Pricing region (local dev only) ─────────────────────────
# Override geo-IP region detection for local development
# Values: it | eu | us (ignored in production where Vercel/Cloudflare headers exist)
# PRICING_REGION=it

# ─── ScraperAPI (optional, fallback for WAF-protected sites) ──
# If set, extractions blocked by AWS WAF / Cloudflare / etc. are retried
# via ScraperAPI's residential proxy before surfacing the error to the user.
# Sign up at https://www.scraperapi.com (5k req/month free tier).
SCRAPERAPI_KEY=

# ─── Stripe ───────────────────────────────────────────────────
# Required for billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (server-side) — optional, features degrade gracefully
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_PACK_500_PRICE_ID=price_...
STRIPE_PACK_2000_PRICE_ID=price_...
STRIPE_PACK_5000_PRICE_ID=price_...

# Price IDs (client-side, exposed to browser)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PACK_500_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PACK_2000_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PACK_5000_PRICE_ID=price_...
